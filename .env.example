# Copy to .env and adjust. Every value is optional — `docker compose up -d`
# works with no .env at all (a token is auto-generated and printed in the logs).

# Bearer token every agent uses to authenticate. Leave unset to auto-generate
# one on first boot (persisted to the volume). To pin your own:
#   openssl rand -hex 32
# SWITCHBOARD_MCP_TOKEN=

# Host port to publish (container always listens on 3107).
# SWITCHBOARD_PORT=3107

# Public URL agents should use to reach this instance — only needed behind a
# reverse proxy or custom domain. If unset, the server auto-detects it from the
# Host header of each request (so the install one-liner self-targets correctly).
# SWITCHBOARD_PUBLIC_BASE=https://switchboard.example.com
