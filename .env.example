# Shared bearer token every agent uses to authenticate to the switchboard.
# Generate a strong value (e.g. `openssl rand -hex 32`) and reuse it in every client config.
SWITCHBOARD_MCP_TOKEN=your-secret-token-here

# Optional: override the HTTP port (default 3107) and SQLite path (default /data/switchboard.db).
# PORT=3107
# SWITCHBOARD_DB_PATH=/data/switchboard.db
